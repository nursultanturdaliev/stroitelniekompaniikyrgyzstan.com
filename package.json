{
  "name": "stroitelniekompaniikyrgyzstan.com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "daily:update": "node scripts/daily-publishing.mjs",
    "deploy": "npm run build && wrangler pages deploy out --project-name=stroitelniekompaniikyrgyzstan",
    "preview": "npm run build && npx serve out",
    "pages:dev": "npm run build && wrangler pages dev out",
    "scrape:sources": "python3 scripts/scrape-all-sources.py --out scraped/merged-companies.json",
    "scrape:passports": "python3 scripts/scrape-all-sources.py --passport-only --merged-in scraped/merged-companies.json --out scraped/merged-companies.json"
  },
  "dependencies": {
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250317.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.6.0"
  }
}
